        "from google.colab import drive\n",
        "drive.mount('/content/drive', force_remount=True)\n",
        "\n",
        "import csv\n",
        "import os\n",
        "import time\n",
        "import requests\n",
        "import urllib3\n",
        "\n",
        "from datetime import datetime\n",
        "from urllib.parse import urlparse\n",
        "from requests.adapters import HTTPAdapter\n",
        "from urllib3.util.retry import Retry\n",
        "\n",
        "# =========================================================\n",
        "# CAMINHOS\n",
        "# =========================================================\n",
        "\n",
        "CSV_PATH = \"/content/iquine.csv\"\n",
        "\n",
        "OUTPUT_DIR = \"/content/drive/MyDrive/Itrak_img/itrak/img\"\n",
        "\n",
        "CHECKPOINT_FILE = \"/content/drive/MyDrive/Itrak_img/itrak/checkpoint.txt\"\n",
        "\n",
        "LOG_FILE = \"/content/drive/MyDrive/Itrak_img/itrak/erros.log\"\n",
        "\n",
        "# =========================================================\n",
        "# CONFIGURAÇÕES\n",
        "# =========================================================\n",
        "\n",
        "LINHA_INICIAL = 82290\n",
        "BLOCO = 500000\n",
        "TIMEOUT = 120\n",
        "PAUSA = 0.2\n",
        "\n",
        "# =========================================================\n",
        "# VALIDAÇÕES\n",
        "# =========================================================\n",
        "\n",
        "if not os.path.exists(CSV_PATH):\n",
        "    raise Exception(f\"CSV não encontrado em: {CSV_PATH}\")\n",
        "\n",
        "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
        "\n",
        "print(\"CSV encontrado:\", CSV_PATH)\n",
        "print(\"Destino:\", OUTPUT_DIR)\n",
        "\n",
        "# =========================================================\n",
        "# IGNORA AVISO SSL\n",
        "# =========================================================\n",
        "\n",
        "urllib3.disable_warnings(\n",
        "    urllib3.exceptions.InsecureRequestWarning\n",
        ")\n",
        "\n",
        "# =========================================================\n",
        "# SESSION COM RETRY\n",
        "# =========================================================\n",
        "\n",
        "session = requests.Session()\n",
        "\n",
        "retry = Retry(\n",
        "    total=3,\n",
        "    backoff_factor=2,\n",
        "    status_forcelist=[500, 502, 503, 504]\n",
        ")\n",
        "\n",
        "adapter = HTTPAdapter(max_retries=retry)\n",
        "\n",
        "session.mount(\"http://\", adapter)\n",
        "session.mount(\"https://\", adapter)\n",
        "\n",
        "# =========================================================\n",
        "# CHECKPOINT\n",
        "# =========================================================\n",
        "\n",
        "def ler_checkpoint():\n",
        "    return LINHA_INICIAL\n",
        "\n",
        "\n",
        "def salvar_checkpoint(linha):\n",
        "    with open(CHECKPOINT_FILE, \"w\") as f:\n",
        "        f.write(str(linha))\n",
        "\n",
        "# =========================================================\n",
        "# LOG\n",
        "# =========================================================\n",
        "\n",
        "def registrar_erro(linha, url, erro):\n",
        "    with open(LOG_FILE, \"a\", encoding=\"utf-8\") as log:\n",
        "        data_hora = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n",
        "\n",
        "        log.write(f\"[{data_hora}]\\n\")\n",
        "        log.write(f\"LINHA: {linha}\\n\")\n",
        "        log.write(f\"URL: {url}\\n\")\n",
        "        log.write(f\"ERRO: {erro}\\n\")\n",
        "        log.write(\"-\" * 100 + \"\\n\")\n",
        "\n",
        "# =========================================================\n",
        "# UTILITÁRIOS\n",
        "# =========================================================\n",
        "\n",
        "def limpar_nome(nome):\n",
        "    if not nome:\n",
        "        return \"vazio\"\n",
        "\n",
        "    nome = str(nome)\n",
        "\n",
        "    caracteres_invalidos = r'<>:\"/\\|?*'\n",
        "\n",
        "    for c in caracteres_invalidos:\n",
        "        nome = nome.replace(c, \"_\")\n",
        "\n",
        "    return nome.strip()\n",
        "\n",
        "\n",
        "def formatar_data(data_str):\n",
        "    if not data_str:\n",
        "        return \"sem_data\"\n",
        "\n",
        "    data_str = str(data_str)\n",
        "\n",
        "    data_str = (\n",
        "        data_str\n",
        "        .replace(\"/\", \"-\")\n",
        "        .replace(\":\", \"-\")\n",
        "        .replace(\" \", \"_\")\n",
        "    )\n",
        "\n",
        "    return limpar_nome(data_str)\n",
        "\n",
        "\n",
        "def obter_extensao(url):\n",
        "    parsed_url = urlparse(url)\n",
        "\n",
        "    ext = os.path.splitext(parsed_url.path)[1].lower()\n",
        "\n",
        "    extensoes_validas = [\n",
        "        \".jpg\",\n",
        "        \".jpeg\",\n",
        "        \".png\",\n",
        "        \".gif\",\n",
        "        \".webp\",\n",
        "        \".pdf\"\n",
        "    ]\n",
        "\n",
        "    if ext not in extensoes_validas:\n",
        "        ext = \".jpg\"\n",
        "\n",
        "    return ext\n",
        "\n",
        "\n",
        "def gerar_nome_unico(caminho_base):\n",
        "    if not os.path.exists(caminho_base):\n",
        "        return caminho_base\n",
        "\n",
        "    base, ext = os.path.splitext(caminho_base)\n",
        "\n",
        "    contador = 1\n",
        "\n",
        "    while True:\n",
        "        novo_caminho = f\"{base}_DUPLI_{contador}{ext}\"\n",
        "\n",
        "        if not os.path.exists(novo_caminho):\n",
        "            return novo_caminho\n",
        "\n",
        "        contador += 1\n",
        "\n",
        "# =========================================================\n",
        "# DOWNLOAD\n",
        "# =========================================================\n",
        "\n",
        "def baixar_arquivo(url, caminho_destino):\n",
        "    try:\n",
        "        response = session.get(\n",
        "            url,\n",
        "            stream=True,\n",
        "            timeout=TIMEOUT,\n",
        "            verify=False\n",
        "        )\n",
        "\n",
        "        response.raise_for_status()\n",
        "\n",
        "        with open(caminho_destino, \"wb\") as arquivo:\n",
        "            for chunk in response.iter_content(chunk_size=8192):\n",
        "                if chunk:\n",
        "                    arquivo.write(chunk)\n",
        "\n",
        "        return True\n",
        "\n",
        "    except Exception as e:\n",
        "        return str(e)\n",
        "\n",
        "# =========================================================\n",
        "# EXECUÇÃO\n",
        "# =========================================================\n",
        "\n",
        "inicio = ler_checkpoint()\n",
        "fim = inicio + BLOCO\n",
        "\n",
        "sucesso_total = 0\n",
        "erro_total = 0\n",
        "dupli_total = 0\n",
        "pulados_total = 0\n",
        "\n",
        "print(\"\\n========================================\")\n",
        "print(\"INICIANDO DOWNLOAD\")\n",
        "print(\"========================================\")\n",
        "print(f\"Linha inicial : {inicio}\")\n",
        "print(f\"Linha final   : {fim}\")\n",
        "print(f\"CSV           : {CSV_PATH}\")\n",
        "print(f\"Destino       : {OUTPUT_DIR}\")\n",
        "print(\"========================================\\n\")\n",
        "\n",
        "with open(\n",
        "    CSV_PATH,\n",
        "    newline=\"\",\n",
        "    encoding=\"utf-8\",\n",
        "    errors=\"ignore\"\n",
        ") as csvfile:\n",
        "\n",
        "    reader = csv.DictReader(csvfile)\n",
        "\n",
        "    for i, row in enumerate(reader):\n",
        "\n",
        "        if i < inicio:\n",
        "            continue\n",
        "\n",
        "        if i >= fim:\n",
        "            print(\"\\nBloco concluído.\")\n",
        "            break\n",
        "\n",
        "        url = row.get(\"urlImagem\")\n",
        "\n",
        "        if not url:\n",
        "            pulados_total += 1\n",
        "            salvar_checkpoint(i + 1)\n",
        "            continue\n",
        "\n",
        "        nf = limpar_nome(\n",
        "            row.get(\"NF/Documento\")\n",
        "        )\n",
        "\n",
        "        cnpj_emitente = limpar_nome(\n",
        "            row.get(\"Emitente - CPF/CNPJ\")\n",
        "        )\n",
        "\n",
        "        cnpj_destinatario = limpar_nome(\n",
        "            row.get(\"Destinatário - CPF/CNPJ\")\n",
        "        )\n",
        "\n",
        "        data_criacao = formatar_data(\n",
        "            row.get(\"Data de Criação\")\n",
        "        )\n",
        "\n",
        "        ext = obter_extensao(url)\n",
        "\n",
        "        nome_arquivo = (\n",
        "            f\"{nf}_\"\n",
        "            f\"{cnpj_emitente}_\"\n",
        "            f\"{cnpj_destinatario}_\"\n",
        "            f\"{data_criacao}\"\n",
        "            f\"{ext}\"\n",
        "        )\n",
        "\n",
        "        caminho_base = os.path.join(\n",
        "            OUTPUT_DIR,\n",
        "            nome_arquivo\n",
        "        )\n",
        "\n",
        "        caminho_arquivo = gerar_nome_unico(caminho_base)\n",
        "\n",
        "        if caminho_arquivo != caminho_base:\n",
        "            dupli_total += 1\n",
        "            print(f\"[DUPLI] {os.path.basename(caminho_arquivo)}\")\n",
        "\n",
        "        resultado = baixar_arquivo(\n",
        "            url,\n",
        "            caminho_arquivo\n",
        "        )\n",
        "\n",
        "        if resultado is True:\n",
        "            sucesso_total += 1\n",
        "\n",
        "            print(\n",
        "                f\"[LINHA {i}] Baixado: \"\n",
        "                f\"{os.path.basename(caminho_arquivo)}\"\n",
        "            )\n",
        "\n",
        "        else:\n",
        "            erro_total += 1\n",
        "\n",
        "            registrar_erro(\n",
        "                i,\n",
        "                url,\n",
        "                resultado\n",
        "            )\n",
        "\n",
        "            print(f\"[LINHA {i}] ERRO: {resultado}\")\n",
        "\n",
        "        salvar_checkpoint(i + 1)\n",
        "\n",
        "        time.sleep(PAUSA)\n",
        "\n",
        "print(\"\\n========================================\")\n",
        "print(\"FINALIZADO\")\n",
        "print(\"========================================\")\n",
        "print(f\"Última linha : {i}\")\n",
        "print(f\"Sucessos     : {sucesso_total}\")\n",
        "print(f\"Erros        : {erro_total}\")\n",
        "print(f\"Duplicados   : {dupli_total}\")\n",
        "print(f\"Pulados      : {pulados_total}\")\n",
        "print(\"========================================\")"
      ],
